datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

model User {
  id                  String            @id @default(uuid())
  username            String            @unique
  email               String            @unique
  passwordHash        String
  avatar              String?
  publicKey           String?           // For E2EE key exchange
  encryptedPrivateKey String?           // Encrypted with PIN-derived key for backup
  keySalt             String?           // Salt used for deriving the key from PIN
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  participants        ChatParticipant[]
  messages            Message[]
  refreshTokens       RefreshToken[]
}

model Chat {
  id           String            @id @default(uuid())
  type         ChatType          @default(DIRECT)
  name         String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  participants ChatParticipant[]
  messages     Message[]
}

enum ChatType {
  DIRECT
  GROUP
}

model ChatParticipant {
  id        String   @id @default(uuid())
  chatId    String
  userId    String
  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([chatId, userId])
}

model Message {
  id        String        @id @default(uuid())
  chatId    String
  senderId  String
  content   String
  createdAt DateTime      @default(now())
  status    MessageStatus @default(SENT)
  chat      Chat          @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender    User          @relation(fields: [senderId], references: [id], onDelete: Cascade)
  embedding MessageEmbedding?

  @@index([chatId, createdAt])
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
}

model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())
}

model MessageEmbedding {
  id        String   @id @default(uuid())
  messageId String   @unique
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  vector    Unsupported("vector(768)")
  createdAt DateTime @default(now())
}

model ExtractedTask {
  id          String   @id @default(uuid())
  chatId      String
  messageId   String
  title       String
  type        String   // e.g., 'TODO' or 'MEETING'
  dueDate     DateTime?
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())

  chat        Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  message     Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([chatId, isCompleted])
}
